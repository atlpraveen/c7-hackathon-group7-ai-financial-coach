# ---------------------------------------------------------------------------
# AI Financial Coach — backend configuration
# Copy this file to `.env`. EVERY value is optional: the app runs end to end
# with deterministic reasoning, SQLite, and TF-IDF search even with no keys.
# Setting a value lights up the corresponding richer backend automatically.
# ---------------------------------------------------------------------------

# ---- LLM (OpenRouter, OpenAI-compatible) ----------------------------------
# Enables LLM routing, narration, AI transaction categorization, and streaming.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
COACH_MODEL=anthropic/claude-opus-4-8
ROUTER_MODEL=anthropic/claude-3.5-haiku
# Legacy direct-Anthropic key (used only if OPENROUTER_API_KEY is empty).
ANTHROPIC_API_KEY=

# ---- Database -------------------------------------------------------------
# SQLite by default; set a postgresql:// URL for Postgres-backed analytics.
DATABASE_URL=sqlite:///./financial_coach.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/financial_coach

# ---- Vector store ---------------------------------------------------------
# ":memory:" = embedded Qdrant in RAM; a path = embedded on disk;
# an http(s):// URL = remote Qdrant. Empty = pure-Python TF-IDF.
QDRANT_URL=:memory:
QDRANT_API_KEY=
QDRANT_COLLECTION=financial_docs
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ---- Auth -----------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Optional Google OAuth (JWT email/password works without these):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# ---- CORS -----------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
