# ===========================================================================
# Docker Compose environment overrides for the AI Financial Coach.
# Copy to ".env" (next to docker-compose.yml) and fill in only what you want:
#     cp .env.example .env
# EVERY value is optional. With nothing set, the app still runs end-to-end
# (deterministic reasoning, Postgres analytics, Qdrant search). Setting a key
# lights up the corresponding richer feature automatically.
# ===========================================================================

# ---- LLM (OpenRouter, OpenAI-compatible) ----------------------------------
# Enables LLM routing, narration, AI transaction categorization, streaming.
OPENROUTER_API_KEY=
# COACH_MODEL=anthropic/claude-opus-4-8
# ROUTER_MODEL=anthropic/claude-3.5-haiku

# ---- Auth -----------------------------------------------------------------
# Set a long random string for production. Email/password login works without
# Google OAuth; fill these only if you want "Sign in with Google".
JWT_SECRET=change-me-to-a-long-random-string
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---- Hosting (only change if you remap ports in docker-compose.yml) --------
# FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
